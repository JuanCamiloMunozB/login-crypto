# ---------------------------------------------------------------------------
# Environment template for docker-compose. Copy to .env and fill in real values:
#     cp .env.example .env
# The .env file holds secrets and is git-ignored — never commit it.
# ---------------------------------------------------------------------------

# --- PostgreSQL ---
POSTGRES_DB=logindb
POSTGRES_USER=loginuser
# Use a strong, unique password in any non-local environment.
POSTGRES_PASSWORD=change-me

# --- JWT signing key ---
# MUST be at least 32 bytes (256 bits) for HMAC-SHA256.
# Generate one with:  openssl rand -base64 48
APP_JWT_SECRET=change-me-to-a-secure-random-at-least-32-byte-value

# JWT lifetime in milliseconds (default 1h).
APP_JWT_EXPIRATION=3600000

# --- Initial admin account (seeded only on first startup) ---
# The seeded admin is forced to change this password on first login.
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me

# --- Application config (environment-specific, NOT secrets) ---
# Comma-separated list of allowed CORS origins (the frontend URL).
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
# Hibernate schema management: 'update' for dev, 'validate' or 'none' for production.
SPRING_JPA_DDL_AUTO=update

# --- Host port mappings (optional; defaults shown) ---
DB_PORT=5432
BACKEND_PORT=8081
FRONTEND_PORT=3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8081
